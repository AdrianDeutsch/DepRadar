root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
# File-scoped namespaces are the house style.
csharp_style_namespace_declarations = file_scoped:warning
csharp_prefer_braces = true:silent
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
# Prefer modern language features that carry their weight.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_members = when_on_single_line:suggestion
dotnet_style_readonly_field = true:warning
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# --- Deliberate analyzer waivers ---------------------------------------------
# We run AnalysisLevel=latest-recommended (strict). These four opt-in rules are
# consciously waived; everything else stays an error via TreatWarningsAsErrors.
#
# CA1848/CA1873: LoggerMessage source-gen delegates are overkill for this app's
# log volume AND the generator does not support generic declaring types such as
# LoggingBehavior<TRequest,TResponse>. Plain structured logging is intentional.
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none
# CA1711/CA1716: RequestHandlerDelegate<T> and the `next` parameter mirror the
# well-known mediator idiom; the familiarity win outweighs the naming guidance.
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1716.severity = none

[*.{csproj,props,targets}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
